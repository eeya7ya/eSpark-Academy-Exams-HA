# ── Database (PostgreSQL — e.g. Neon, Supabase or Vercel Postgres) ──
# Pooled connection used by the app at runtime
POSTGRES_URL="postgresql://user:password@host/dbname?sslmode=require"
# Direct (unpooled) connection used by `npx prisma db push` / migrations
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# ── Admin dashboard credentials ─────────────────────────────────────
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-to-a-strong-password"
# Optional: separate secret for signing session cookies
# ADMIN_SESSION_SECRET="a-long-random-string"

# ── File storage (certificates) ─────────────────────────────────────
# On Vercel, add a Blob store and this token is set automatically.
# Without it, files are stored on the local filesystem (dev only).
# BLOB_READ_WRITE_TOKEN=""

# Optional: max upload size in bytes (default 25MB)
# MAX_FILE_SIZE="26214400"
